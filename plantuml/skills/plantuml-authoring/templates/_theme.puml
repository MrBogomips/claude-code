  ParticipantFontColor       $neutral
  ActorBackgroundColor       $surface
  ActorBorderColor           $neutral
  ActorFontColor             $neutral
  GroupBackgroundColor       $surface
  GroupBorderColor           $neutral
  BoxBorderColor             $neutral
}

