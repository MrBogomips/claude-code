# {{PROJECT_NAME}} Development Container
# Generated by devcontainer-generator v2.4.0

# Base image — selected based on primary language stack
FROM {{BASE_IMAGE}} AS base

# Avoid warnings by switching to noninteractive
ENV DEBIAN_FRONTEND=noninteractive

# System dependencies (always included)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    wget \
    gnupg2 \
    ca-certificates \
    lsb-release \
    jq \
    # Firewall prerequisites (always included)
    iptables \
    dnsutils \
    # {{APT_EXTRA}} — Insert stack-specific and service client packages
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# {{RUNTIME_LAYERS}} — Insert runtime installation from stack reference files
# (e.g., Python layer when Node.js is the primary stack)

# Copy devcontainer scripts and firewall rules
COPY scripts/ /devcontainer/scripts/
COPY firewall-rules.conf /devcontainer/firewall-rules.conf

# Ensure scripts are executable
RUN chmod +x /devcontainer/scripts/*.sh

# Default shell
ENV SHELL=/bin/zsh

# Restore interactive frontend
ENV DEBIAN_FRONTEND=dialog
