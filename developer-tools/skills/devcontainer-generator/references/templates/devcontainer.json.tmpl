// {{PROJECT_NAME}} Development Container
// Generated by devcontainer-generator v2.4.0
{
  "name": "{{PROJECT_NAME}} - Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/{{PROJECT_NAME}}",

  // Lifecycle commands
  "postCreateCommand": "/devcontainer/scripts/post-create.sh",
  "postStartCommand": "sudo bash /devcontainer/scripts/apply-firewall.sh /devcontainer/firewall-rules.conf",

  // {{INITIALIZE_COMMAND}} — Ensure credential files exist on host before bind mount
  // Generated: "initializeCommand": "bash -c 'test -f ... || touch ...'"
  // Omitted entirely if no credentials selected in Step 1b

  // {{MOUNTS}} — Read-only bind mounts for host credential files
  // Generated: "mounts": ["source=${localEnv:HOME}/...,target=/tmp/...,type=bind,readonly"]
  // Omitted entirely if no credentials selected in Step 1b

  // Network admin capability (required for firewall — always present)
  "capAdd": ["NET_ADMIN"],

  // Devcontainer features
  "features": {
    // IMPORTANT: Do NOT add username, userUid, or userGid here.
    // Automatic detection avoids GID conflicts with base image users.
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
    // {{FEATURES}} — Insert additional features from stack reference files
  },

  // VS Code customizations
  "customizations": {
    "vscode": {
      "extensions": [
        // Common tools (always included)
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "christian-kohler.path-intellisense"
        // {{EXTENSIONS}} — Insert stack-specific and service-specific extensions
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
        // {{SETTINGS}} — Insert stack-specific editor settings
      }
    }
  },

  // Port forwarding
  "forwardPorts": [
    // {{PORTS}} — Insert ports from stack frameworks and services
  ],
  "portsAttributes": {
    // {{PORT_ATTRS}} — Insert port labels and auto-forward behavior
  },

  // Environment variables
  "containerEnv": {
    // {{CONTAINER_ENV}} — Insert telemetry opt-out and dev mode vars from stack reference
  },

  // Pass through credentials from host
  "remoteEnv": {
    // {{REMOTE_ENV}} — Insert project-specific environment variables
  },

  // remoteUser: always "vscode" — guaranteed by common-utils:2 feature.
  // Never use image-specific users (node, python, etc.) as they may not survive feature layering.
  "remoteUser": "vscode"
}
