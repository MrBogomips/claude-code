{
  "name": "mrbogomips-claude-marketplace",
  "version": "1.0.0",
  "description": "A collection of developer tools and plugins for Claude Code",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint . && markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "validate": "node scripts/validate-plugins.js",
    "new-plugin": "node scripts/new-plugin.js",
    "build": "node scripts/build-marketplace.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plugins",
    "marketplace",
    "anthropic"
  ],
  "author": {
    "name": "Mr Bogomips",
    "email": "giovanni.costagliola@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^17.3.0",
    "markdownlint-cli2": "^0.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
