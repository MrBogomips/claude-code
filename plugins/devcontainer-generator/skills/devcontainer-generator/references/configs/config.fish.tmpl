# {{PROJECT_NAME}} Development Container - Fish Shell Configuration
# Generated by devcontainer-generator

# Environment Variables
set -gx EDITOR 'code --wait'
set -gx VISUAL 'code --wait'
set -gx LANG 'en_US.UTF-8'
set -gx LC_ALL 'en_US.UTF-8'

# Path Setup
fish_add_path $HOME/.local/bin
# {{PATH_DOTNET}} - Add if .NET detected:
# fish_add_path $HOME/.dotnet/tools

# FZF Configuration
set -gx FZF_DEFAULT_OPTS '--height 40% --layout=reverse --border'

# Custom Greeting
function fish_greeting
    echo "Development Container: {{PROJECT_NAME}}"
    # {{GREETING_NODE}} - Add if Node.js detected:
    # echo "   Node.js: "(node --version 2>/dev/null || echo "not installed")
    # {{GREETING_DOTNET}} - Add if .NET detected:
    # echo "   .NET:    "(dotnet --version 2>/dev/null || echo "not installed")
    # {{GREETING_PYTHON}} - Add if Python detected:
    # echo "   Python:  "(python3 --version 2>/dev/null | cut -d' ' -f2 || echo "not installed")
end

# Navigation Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# Git Aliases
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias glog='git log --oneline --graph --decorate'

# Docker Aliases
alias dc='docker compose'
alias dps='docker ps'
alias dimg='docker images'

