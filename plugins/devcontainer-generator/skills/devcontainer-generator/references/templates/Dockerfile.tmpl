# RUN dotnet workload install aspire

# =============================================================================
# Python Installation
# =============================================================================
# {{INSTALL_PYTHON}} - Add if Python detected:
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     python3-dev \
#     python3-pip \
#     python3-venv \
#     && apt-get clean \
#     && rm -rf /var/lib/apt/lists/*

# {{INSTALL_PYTHON_PACKAGES}} - Add project-specific Python packages:
# RUN pip3 install --no-cache-dir --break-system-packages \
#     package1 \
#     package2

# =============================================================================
# Go Installation
# =============================================================================
# {{INSTALL_GO}} - Add if Go detected (use go base image instead):
# Already included in mcr.microsoft.com/devcontainers/go base image

# =============================================================================
# Rust Installation
# =============================================================================
# {{INSTALL_RUST}} - Add if Rust detected (use rust base image instead):
# Already included in mcr.microsoft.com/devcontainers/rust base image

# =============================================================================
# Copy Configuration Files
# =============================================================================
COPY scripts/ /devcontainer/scripts/
COPY config/ /devcontainer/config/
# {{COPY_FIREWALL}} - Add if firewall rules needed:
# COPY firewall-rules.conf /devcontainer/firewall-rules.conf

# Ensure scripts are executable
RUN chmod +x /devcontainer/scripts/*.sh

# =============================================================================
# Set Default Shell
# =============================================================================
# {{SHELL_ZSH}}:
ENV SHELL=/bin/zsh
# {{SHELL_FISH}}:
# ENV SHELL=/usr/bin/fish
# {{SHELL_BASH}}:
# ENV SHELL=/bin/bash

# Switch back to dialog for any ad-hoc use of apt-get
ENV DEBIAN_FRONTEND=dialog
