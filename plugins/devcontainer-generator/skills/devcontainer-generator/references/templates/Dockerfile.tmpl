# {{PROJECT_NAME}} Development Container
# Multi-runtime Dockerfile with tooling
# Generated by devcontainer-generator

# =============================================================================
# Base Image Selection
# =============================================================================
# {{BASE_IMAGE}} - Select based on primary language:
# - .NET: mcr.microsoft.com/devcontainers/dotnet:{{DOTNET_VERSION}}
# - Node.js: mcr.microsoft.com/devcontainers/javascript-node:{{NODE_VERSION}}
# - Python: mcr.microsoft.com/devcontainers/python:{{PYTHON_VERSION}}
# - Go: mcr.microsoft.com/devcontainers/go:latest
# - Rust: mcr.microsoft.com/devcontainers/rust:latest
# - Universal: mcr.microsoft.com/devcontainers/universal:2

FROM mcr.microsoft.com/devcontainers/base:ubuntu AS base

# Avoid warnings by switching to noninteractive
ENV DEBIAN_FRONTEND=noninteractive

# =============================================================================
# System Dependencies
# =============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials
    build-essential \
    curl \
    wget \
    gnupg2 \
    ca-certificates \
    lsb-release \
    # Shell and utilities
    fish \
    zsh \
    jq \
    httpie \
    # {{APT_FZF}} - Add if fzf selected:
    # fzf \
    # Graphics and document processing (optional)
    # graphviz \
    # imagemagick \
    # {{APT_POSTGRES}} - Add if PostgreSQL detected:
    # postgresql-client \
    # {{APT_PLAYWRIGHT}} - Add if Playwright detected (Ubuntu Noble naming):
    # libnss3 \
    # libnspr4 \
    # libatk1.0-0 \
    # libatk-bridge2.0-0 \
    # libcups2 \
    # libdrm2 \
    # libxkbcommon0 \
    # libxcomposite1 \
    # libxdamage1 \
    # libxfixes3 \
    # libxrandr2 \
    # libgbm1 \
    # libasound2t64 \
    # libpango-1.0-0 \
    # libcairo2 \
    # Cleanup
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# =============================================================================
# Node.js Installation
# =============================================================================
# {{INSTALL_NODEJS}} - Add if Node.js detected:
# RUN curl -fsSL https://deb.nodesource.com/setup_{{NODE_VERSION}}.x | bash - \
#     && apt-get install -y nodejs \
#     && apt-get clean \
#     && rm -rf /var/lib/apt/lists/*

