# Note: 'version' key is omitted as Docker Compose v2+ ignores it
# See: https://docs.docker.com/compose/compose-file/04-version-and-name/

services:
  # ===========================================================================
  # Main Development Container
  # ===========================================================================
  devcontainer:
    build:
      context: .
      dockerfile: Dockerfile
    volumes:
      # Workspace mount
      - ..:/workspaces/{{PROJECT_NAME}}:cached
      # Named volumes for caches
      # {{VOLUME_NUGET}} - Add if .NET detected:
      # - devcontainer-{{PROJECT_NAME}}-nuget:/home/vscode/.nuget
      # {{VOLUME_PNPM}} - Add if pnpm detected:
      # - devcontainer-{{PROJECT_NAME}}-pnpm-store:/home/vscode/.local/share/pnpm/store
      # {{VOLUME_NPM}} - Add if npm detected:
      # - devcontainer-{{PROJECT_NAME}}-npm-cache:/home/vscode/.npm
      # {{VOLUME_YARN}} - Add if yarn detected:
      # - devcontainer-{{PROJECT_NAME}}-yarn-cache:/home/vscode/.yarn
    environment:
      # {{ENV_POSTGRES}} - Add if PostgreSQL selected:
      # - ConnectionStrings__PostgreSQL=Host=postgres;Port=5432;Database={{PROJECT_NAME}};Username=postgres;Password=postgres
      # {{ENV_RABBITMQ}} - Add if RabbitMQ selected:
      # - ConnectionStrings__RabbitMQ=Host=rabbitmq;Port=5672
      # {{ENV_REDIS}} - Add if Redis selected:
      # - ConnectionStrings__Redis=redis:6379
      # {{ENV_MONGODB}} - Add if MongoDB selected:
      # - ConnectionStrings__MongoDB=mongodb://admin:admin@mongodb:27017
      # {{ENV_AZURITE}} - Add if Azurite selected:
      # - AzureStorage__ConnectionString=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;QueueEndpoint=http://azurite:10001/devstoreaccount1;TableEndpoint=http://azurite:10002/devstoreaccount1
      # Telemetry disabled
      - DOTNET_CLI_TELEMETRY_OPTOUT=1
      - NEXT_TELEMETRY_DISABLED=1
      - NG_CLI_ANALYTICS=false
      # Development mode
      - NODE_ENV=development
      - ASPNETCORE_ENVIRONMENT=Development
      - PYTHONUNBUFFERED=1
    # {{DEPENDS_ON}} - Add based on selected services:
    # depends_on:
    #   - postgres
    #   - rabbitmq
    #   - redis
    #   - mongodb
    #   - azurite
    # {{CAP_ADD_FIREWALL}} - Add if firewall enabled:
    # cap_add:
    #   - NET_ADMIN
    # Keep container running
    command: sleep infinity

