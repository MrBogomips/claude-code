// NOTE: This file uses JSONC format (JSON with Comments) which is supported by VS Code and devcontainers.
// Comments will be preserved in the generated file.
{
  "name": "{{PROJECT_NAME}} - Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "{{WORKSPACE_FOLDER}}",

  // Run post-create script
  "postCreateCommand": "/devcontainer/scripts/post-create.sh",

  // Features - Add/remove based on detected stack
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
    // {{FEATURE_AZURE_CLI}} - Add if Azure detected:
    // "ghcr.io/devcontainers/features/azure-cli:1": {
    //   "installBicep": true,
    //   "version": "latest"
    // }
    // {{FEATURE_GITHUB_CLI}} - Add if gh selected:
    // "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // VS Code Customizations - Adjust based on detected stack
  "customizations": {
    "vscode": {
      "extensions": [
        // Common Tools
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "editorconfig.editorconfig",
        "christian-kohler.path-intellisense",
        "mikestead.dotenv"

        // {{EXTENSIONS_FRONTEND}} - Add if Node.js detected:
        // "dbaeumer.vscode-eslint",
        // "esbenp.prettier-vscode",
        // "bradlc.vscode-tailwindcss"

        // {{EXTENSIONS_ANGULAR}} - Add if Angular detected:
        // "angular.ng-template"

        // {{EXTENSIONS_REACT}} - Add if React/Next.js detected:
        // "dsznajder.es7-react-js-snippets"

        // {{EXTENSIONS_DOTNET}} - Add if .NET detected:
        // "ms-dotnettools.csdevkit",
        // "ms-dotnettools.csharp",
        // "ms-dotnettools.vscode-dotnet-runtime"

        // {{EXTENSIONS_PYTHON}} - Add if Python detected:
        // "ms-python.python",
        // "ms-python.vscode-pylance"

        // {{EXTENSIONS_DOCKER}} - Add if docker-compose or Dockerfile exists:
        // "ms-azuretools.vscode-docker"

        // {{EXTENSIONS_DATABASE}} - Add if PostgreSQL detected:
        // "ckolkman.vscode-postgres"

        // {{EXTENSIONS_TESTING}} - Add if Playwright detected:
        // "ms-playwright.playwright"
      ],
      "settings": {
        // Editor
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,

        // Files
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,

        // Terminal
        "terminal.integrated.defaultProfile.linux": "zsh"

        // {{SETTINGS_TYPESCRIPT}} - Add if TypeScript detected:
        // "[typescript]": {
        //   "editor.defaultFormatter": "esbenp.prettier-vscode"
        // },
        // "[typescriptreact]": {
        //   "editor.defaultFormatter": "esbenp.prettier-vscode"
        // }

        // {{SETTINGS_CSHARP}} - Add if .NET detected:
        // "[csharp]": {
        //   "editor.defaultFormatter": "ms-dotnettools.csharp"
        // }

        // {{SETTINGS_PYTHON}} - Add if Python detected:
        // "[python]": {
        //   "editor.defaultFormatter": "ms-python.python"
        // }
      }
    }
  },

  // Port Forwarding - Adjust based on detected frameworks and services
  "forwardPorts": [
    // {{PORTS_NEXTJS}} 3000
    // {{PORTS_ANGULAR}} 4200
    // {{PORTS_VITE}} 5173
    // {{PORTS_STORYBOOK}} 6006
    // {{PORTS_DOTNET}} 5000, 5001
    // {{PORTS_POSTGRES}} 5432
    // {{PORTS_RABBITMQ}} 5672, 15672
    // {{PORTS_REDIS}} 6379
    // {{PORTS_MONGODB}} 27017
    // {{PORTS_AZURITE}} 10000, 10001, 10002
  ],
  "portsAttributes": {
    // {{PORT_ATTRS}} - Configure based on detected services
    // "3000": { "label": "Next.js Dev Server", "onAutoForward": "notify" },
    // "4200": { "label": "Angular Dev Server", "onAutoForward": "notify" },
    // "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },

  // Environment Variables - Telemetry opt-out
  "containerEnv": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "NEXT_TELEMETRY_DISABLED": "1",
    "NG_CLI_ANALYTICS": "false",
    "GATSBY_TELEMETRY_DISABLED": "1",
    "NUXT_TELEMETRY_DISABLED": "1",
    // Development mode
    "NODE_ENV": "development",
    "ASPNETCORE_ENVIRONMENT": "Development",
    "PYTHONUNBUFFERED": "1"
  },

  // Pass through credentials from host
  "remoteEnv": {
    // {{REMOTE_ENV}} - Add project-specific environment variables
  },

  // Mount points
  "mounts": [
    // {{MOUNT_CLAUDE}} - Add if Claude Code selected:
    // "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  // User
  "remoteUser": "vscode"
}
